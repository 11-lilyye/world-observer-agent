# Optional: point the agent at your Obsidian vault.
# If omitted, World Observer Agent uses ./data/obsidian_vault as a safe local placeholder.
OBSIDIAN_VAULT=./data/obsidian_vault

# Runtime outputs are written here.
WORLD_OBSERVER_OUTPUT_DIR=./data/04_实验设计记录

# World source mode:
# - auto: TrendRadar/newsnow + RSS, then offline seed if network fails.
# - offline: no network, useful for smoke tests.
WORLD_OBSERVER_SOURCE_MODE=auto

# Optional RSS/Atom feeds, comma separated.
WORLD_OBSERVER_FEEDS=https://sspai.com/feed,https://www.geekpark.net/rss,https://www.ifanr.com/feed,https://www.technologyreview.com/feed/

# Creation engine:
# - auto: Codex first, then local model if configured.
# - codex: use codex exec.
# - local: use Ollama-compatible local model.
WORLD_OBSERVER_CREATION_ENGINE=auto

# Optional local model settings.
WORLD_OBSERVER_LLM=local
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_NUM_PREDICT=1800

# Optional OpenAI-compatible API key for future integrations.
OPENAI_API_KEY=

# TrendRadar/newsnow compatible hot-list API.
TREND_RADAR_ENABLED=true
TREND_RADAR_API_URL=https://newsnow.busiyi.world/api/s
TREND_RADAR_PLATFORMS=zhihu,weibo,douyin,bilibili-hot-search,toutiao,baidu,thepaper,wallstreetcn-hot,cls-hot,ifeng

# Image generation is prompt-only by default for public installs.
WORLD_OBSERVER_IMAGE_BACKEND=prompt_only
WORLD_OBSERVER_IMAGE_FALLBACK_BACKEND=prompt_only

# Batch writing defaults.
WORLD_OBSERVER_BATCH_SIZE=2
WORLD_OBSERVER_BATCH_ARTICLE_MIN_CHARS=1000
WORLD_OBSERVER_BATCH_ARTICLE_MAX_CHARS=1800
